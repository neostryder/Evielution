---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBasePath } from "../utils/site-paths";
---

<BaseLayout title="Page not found" description="The page you were looking for does not live in this room." currentPath="/404">
  <section class="page-intro panel">
    <p class="eyebrow">Lost in the house</p>
    <h1>That room is not here yet.</h1>
    <p>
      Try the home map instead. Evielution is still growing, and some doors will appear over time.
    </p>
    <p><a class="pill" href={withBasePath("/")}>Return to the home map</a></p>
  </section>
</BaseLayout>
