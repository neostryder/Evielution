---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBasePath } from "../utils/site-paths";

const items = (await getCollection("projects"))
  .filter((entry) => entry.data.category === "workshop")
  .sort((left, right) => Number(right.data.featured) - Number(left.data.featured));
---

<BaseLayout
  title="Workshop"
  description="A visible workbench for unfinished ideas, drafts, and things in motion."
  currentPath="/workshop"
>
  <section class="page-intro panel">
    <p class="eyebrow">Workshop</p>
    <h1>The unfinished part of the house is part of the point.</h1>
    <p>
      Evielution is not only a gallery. The workshop keeps drafts, experiments, and evolving material visible without
      pretending they are final.
    </p>
  </section>

  <section class="note-grid">
    <div class="callout">
      <h3>Gallery mode</h3>
      <p>Share the polished pieces that are ready for easy browsing.</p>
    </div>
    <div class="callout">
      <h3>Workshop mode</h3>
      <p>Share the pieces that are alive, unfinished, and still changing.</p>
    </div>
  </section>

  <section class="panel stack">
    <h2>Current workbenches</h2>
    <ul class="card-list">
      {
        items.map((entry) => (
          <li class="entry-card">
            {entry.data.image && (
              <img class="entry-card-image" src={withBasePath(entry.data.image)} alt={entry.data.imageAlt ?? entry.data.title} loading="lazy" />
            )}
            <div class="entry-card-copy">
              <div class="meta-row compact-row">
                <span class="pill">{entry.data.status}</span>
                {entry.data.simulated && <span class="pill simulated-pill">simulated</span>}
              </div>
              <h3>
                <a href={withBasePath(`/projects/${entry.slug}/`)}>{entry.data.title}</a>
              </h3>
              <p>{entry.data.summary}</p>
              <div class="meta-row">
                {entry.data.tags.map((tag) => <span class="pill">{tag}</span>)}
              </div>
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
