---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("writing");

  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const publishedLabel = entry.data.publishedAt
  ? entry.data.publishedAt.toLocaleDateString("en-US", {
      month: "long",
      day: "numeric",
      year: "numeric",
    })
  : "Undated";
---

<BaseLayout title={entry.data.title} description={entry.data.summary} currentPath="/writing">
  <section class="content-header panel">
    <p class="eyebrow">{entry.data.category}</p>
    <h1>{entry.data.title}</h1>
    <p>{entry.data.summary}</p>
    <div class="meta-row">
      <span class="pill">{publishedLabel}</span>
      <span class="pill">{entry.data.visibility}</span>
      {entry.data.simulated && <span class="pill simulated-pill">simulated placeholder</span>}
      {entry.data.tags.map((tag) => <span class="pill">{tag}</span>)}
    </div>

    {entry.data.image && <img class="feature-image" src={entry.data.image} alt={entry.data.imageAlt ?? entry.data.title} />}
  </section>

  {
    entry.data.simulated && (
      <section class="content-note panel">
        <strong>Placeholder notice</strong>
        <p>
          This writing entry is simulated placeholder material used to shape the tone and pacing of the site while the
          real body of work is still being assembled.
        </p>
      </section>
    )
  }

  <article class="content-body panel">
    <Content />
  </article>
</BaseLayout>
