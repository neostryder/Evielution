---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBasePath } from "../../utils/site-paths";

const items = (await getCollection("writing")).sort((left, right) => {
  const leftTime = left.data.publishedAt?.getTime() ?? 0;
  const rightTime = right.data.publishedAt?.getTime() ?? 0;
  return rightTime - leftTime;
});

const formatDate = (value: Date | undefined) =>
  value
    ? value.toLocaleDateString("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric",
      })
    : "Undated";
---

<BaseLayout title="Writing" description="Notes, essays, journals, and writing fragments." currentPath="/writing">
  <section class="page-intro panel">
    <p class="eyebrow">Writing desk</p>
    <h1>Voice, process, and pages in motion.</h1>
    <p>
      This room gathers notes, essays, journals, and other writing that helps visitors understand both the finished
      work and the creative process behind it.
    </p>
  </section>

  <section class="panel stack">
    <h2>Current entries</h2>
    <ul class="card-list">
      {
        items.map((entry) => (
          <li class="entry-card">
            {entry.data.image && (
              <img class="entry-card-image" src={withBasePath(entry.data.image)} alt={entry.data.imageAlt ?? entry.data.title} loading="lazy" />
            )}
            <div class="entry-card-copy">
              <div class="meta-row compact-row">
                <span class="pill">{entry.data.category}</span>
                {entry.data.simulated && <span class="pill simulated-pill">simulated</span>}
              </div>
              <h3>
                <a href={withBasePath(`/writing/${entry.slug}/`)}>{entry.data.title}</a>
              </h3>
              <p>{entry.data.summary}</p>
              <div class="meta-row">
                <span class="pill">{formatDate(entry.data.publishedAt)}</span>
                {entry.data.tags.map((tag) => <span class="pill">{tag}</span>)}
              </div>
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
